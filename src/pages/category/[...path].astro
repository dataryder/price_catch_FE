---
import Layout from '../../layouts/Layout.astro';
import CategoryPage from '../../react-pages/CategoryCatalog';

export async function getStaticPaths() {
  const [searchRes, indexRes] = await Promise.all([
    fetch("https://pricecatcher-lake.iwa.my/data/global_search.json"),
    fetch("https://pricecatcher-lake.iwa.my/indices/item_category_price_index.json")
  ]);

  if (!searchRes.ok) throw new Error("Failed to fetch global search catalog for category routes");
  const data = await searchRes.json();
  
  let indices: Record<string, any> = {};
  if (indexRes.ok) {
    const rawText = await indexRes.text();
    indices = JSON.parse(rawText.replace(/:\s*NaN/g, ": null"));
  }
  
  // Precompute hierarchy at build time
  const uniqueKeys = new Set<string>();
  const hierarchy: any[] = [];
  data.forEach((i) => {
    if (i.item_group) {
      const key = `${i.item_group}|${i.item_category}`;
      if (!uniqueKeys.has(key)) {
        uniqueKeys.add(key);
        hierarchy.push({
          item_group: i.item_group,
          item_category: i.item_category,
        });
      }
    }
  });
  hierarchy.sort((a, b) => a.item_group.localeCompare(b.item_group));

  const paths = [];
  
  // 1. Root /category
  paths.push({ 
    params: { path: undefined }, 
    props: { 
      group: undefined, 
      category: undefined,
      title: "Browse by Categories | OpenPriceCatcher",
      description: "Drill down into product groups and categories to analyze retail prices and historical food trends in Malaysia.",
      image: "/og.png",
      preloadedHierarchy: hierarchy,
      preloadedItems: []
    } 
  });
  
  const groups = new Set();
  const groupCategoryPairs = new Set<string>();
  
  data.forEach((item) => {
    if (item.item_group) {
      groups.add(item.item_group);
      if (item.item_category) {
        groupCategoryPairs.add(`${item.item_group}|${item.item_category}`);
      }
    }
  });
  
  // 2. /category/[group]
  groups.forEach((group: string) => {
    paths.push({ 
      params: { path: group }, 
      props: { 
        group, 
        category: undefined,
        title: `${group} Categories | OpenPriceCatcher`,
        description: `Compare retail prices and analyze trends for products under ${group} in Malaysia.`,
        image: "/og.png",
        preloadedHierarchy: hierarchy,
        preloadedItems: []
      } 
    });
  });
  
  // 3. /category/[group]/[category]
  groupCategoryPairs.forEach((pair) => {
    const [group, category] = pair.split("|");
    const urlSafeCatName = category.replace(/\//g, "--");
    
    // Find WoW change from index
    const categoryData = indices[category] || [];
    const latestData = categoryData[categoryData.length - 1];
    const wowVal = latestData ? latestData.pop_change_pct : null;
    
    let title = `${category} (${group}) Price Trends | OpenPriceCatcher`;
    let description = `Analyze historical price details and trends for ${category} in Malaysia. Sourced from official KPDN open data.`;
    
    if (wowVal !== null && !isNaN(wowVal)) {
      const sign = wowVal > 0 ? "+" : "";
      title = `${category} (${sign}${wowVal.toFixed(2)}% WoW) | OpenPriceCatcher`;
      description = `Track price indices and compare retail prices for ${category} in Malaysia. The index moved by ${sign}${wowVal.toFixed(2)}% this week compared to last week.`;
    }

    const image = `/og/category-${group}-${urlSafeCatName}.png`;

    // Filter items list for this category at build time
    const itemsList = data
      .filter((i) => i.item_group === group && i.item_category === category)
      .sort((a, b) => a.item.localeCompare(b.item));

    paths.push({ 
      params: { path: `${group}/${urlSafeCatName}` }, 
      props: { 
        group, 
        category: urlSafeCatName,
        title,
        description,
        image,
        preloadedHierarchy: hierarchy,
        preloadedItems: itemsList
      } 
    });
  });
  
  return paths;
}

const { group, category, title, description, image, preloadedHierarchy, preloadedItems } = Astro.props;
---

<Layout title={title} description={description} image={image}>
  <!-- Clean JSON data block for AI agents and scrapers -->
  <script id="category-data" type="application/json" set:html={JSON.stringify({
    group,
    category,
    hierarchy: preloadedHierarchy,
    items: preloadedItems
  }, (key, value) => typeof value === 'bigint' ? Number(value) : value)} />

  <CategoryPage 
    group={group} 
    category={category} 
    preloadedHierarchy={preloadedHierarchy}
    preloadedItems={preloadedItems}
    client:load 
  />
</Layout>
